   "source": [
    "# XGBoost is the primary model because it captures nonlinearities and feature interactions seen in EDA.\n",
    "pos_rate = float(y_train.mean())\n",
    "scale_pos_weight = (1 - pos_rate) / pos_rate\n",
    "\n",
    "best_xgb = None\n",
    "\n",
    "for max_depth in [3, 4, 6]:\n",
    "    for lr in [0.03, 0.05, 0.1]:\n",
    "        xgb = XGBClassifier(\n",
    "            n_estimators=3000,\n",
    "            max_depth=max_depth,\n",
    "            learning_rate=lr,\n",
    "            subsample=0.85,\n",
    "            colsample_bytree=0.8,\n",
    "            objective=\"binary:logistic\",\n",
    "            eval_metric=\"aucpr\",\n",
    "            scale_pos_weight=scale_pos_weight,\n",
    "            random_state=RANDOM_SEED,\n",
    "            n_jobs=-1,\n",
    "            early_stopping_rounds=50,\n",
    "        )\n",
    "        xgb.fit(X_train, y_train, eval_set=[(X_val, y_val)], verbose=False)\n",
    "        val_prob = xgb.predict_proba(X_val)[:, 1]\n",
    "        auprc = average_precision_score(y_val, val_prob)\n",
    "\n",
    "        if best_xgb is None or auprc > best_xgb[\"val_auprc\"]:\n",
    "            best_xgb = {\n",
    "                \"params\": {\"max_depth\": max_depth, \"learning_rate\": lr},\n",
    "                \"best_iter\": int(xgb.best_iteration) if xgb.best_iteration is not None else 2999,\n",
    "                \"val_auprc\": float(auprc),\n",
    "            }\n",
    "\n",
    "print(\"Best XGB:\", best_xgb)\n",
    "\n",
    "xgb_final = XGBClassifier(\n",
    "    n_estimators=best_xgb[\"best_iter\"] + 1,\n",
    "    max_depth=best_xgb[\"params\"][\"max_depth\"],\n",
    "    learning_rate=best_xgb[\"params\"][\"learning_rate\"],\n",
    "    subsample=0.85,\n",
    "    colsample_bytree=0.8,\n",
    "    objective=\"binary:logistic\",\n",
    "    eval_metric=\"aucpr\",\n",
    "    scale_pos_weight=scale_pos_weight,\n",
    "    random_state=RANDOM_SEED,\n",
