     ]
    }
   ],
   "source": [
    "# A strict temporal split simulates deployment: train on past, validate on next year, test on final holdout year.\n",
    "TEST_YEAR = int(model_df[\"donation_year\"].max())\n",
    "VAL_YEAR = TEST_YEAR - 1\n",
    "\n",
    "train_mask = model_df[\"donation_year\"] < VAL_YEAR\n",
    "val_mask   = model_df[\"donation_year\"] == VAL_YEAR\n",
    "test_mask  = model_df[\"donation_year\"] == TEST_YEAR\n",
    "\n",
    "X_train, y_train = X[train_mask], y[train_mask]\n",
    "X_val, y_val     = X[val_mask], y[val_mask]\n",
    "X_test, y_test   = X[test_mask], y[test_mask]\n",
    "\n",
    "df_test = model_df[test_mask].copy()\n",
    "\n",
    "print(\"Train years:\", int(model_df.loc[train_mask, \"donation_year\"].min()), \"->\", int(model_df.loc[train_mask, \"donation_year\"].max()))\n",
    "print(\"Val year:\", VAL_YEAR, \"| Test year:\", TEST_YEAR)\n",
    "print(\"Rows (train/val/test):\", len(X_train), len(X_val), len(X_test))\n",
    "print(\"Positive rate (train/val/test):\", float(y_train.mean()), float(y_val.mean()), float(y_test.mean()))"
   ]
