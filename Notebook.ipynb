    "# A complete donor×year grid is created so “no-donation years” exist as explicit rows (required for lapse detection).\n",
    "min_year = int(account_year[\"donation_year\"].min())\n",
    "max_year = int(account_year[\"donation_year\"].max())\n",
    "\n",
    "years = list(range(min_year, max_year + 1))\n",
    "accounts = account_year[\"account_id\"].unique()\n",
    "\n",
    "full_index = pd.DataFrame(itertools.product(accounts, years), columns=[\"account_id\", \"donation_year\"])\n",
    "account_year_full = full_index.merge(account_year, on=[\"account_id\", \"donation_year\"], how=\"left\")\n",
    "\n",
    "# Missing values represent no gifts that year and are filled to preserve numeric features without imputation artifacts.\n",
    "account_year_full[\"gift_count\"] = account_year_full[\"gift_count\"].fillna(0).astype(int)\n",
    "account_year_full[\"total_amount\"] = account_year_full[\"total_amount\"].fillna(0.0)\n",
    "account_year_full[\"gave_in_year\"] = account_year_full[\"gave_in_year\"].fillna(0).astype(int)\n",
    "\n",
    "account_year_full = account_year_full.sort_values([\"account_id\", \"donation_year\"]).reset_index(drop=True)\n",
    "\n",
    "print(\"Panel rows:\", account_year_full.shape[0])\n",
    "display(account_year_full.head(10))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d8e86624-66b3-40fc-ab4d-5af7963cd7ed",
   "metadata": {},
   "source": [
    "## Cell 13 — Leakage-safe lags + eligibility + year-conditional lapse label\n",
    "\n",
    "All features are constructed using lagged (shifted) values to ensure only information available prior to the prediction year is used.  \n",
    "Eligibility defines the at-risk population (gave last year + has ≥2 prior lifetime gifts).  \n",
    "The lapse label is defined behaviorally for each year: eligible donors who do not give in that year are labeled as lapsed."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 15,
   "id": "b059876e-be27-4334-9de6-6e62a2b64383",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Eligible rows: 71407\n",
      "Lapsed rows: 51178\n"
     ]
    }
   ],
   "source": [
    "# All features are constructed using only information available prior to the prediction year (shifted lags).\n",
    "account_year_full[\"lifetime_gifts_through_year\"] = (\n",
    "    account_year_full.groupby(\"account_id\")[\"gift_count\"].cumsum()\n",
    ")\n",
    "\n",
    "# “Through last year” is created via shift(1) to prevent current-year information from leaking into features.\n",
    "account_year_full[\"lifetime_gifts_through_last_year\"] = (\n",
    "    account_year_full.groupby(\"account_id\")[\"lifetime_gifts_through_year\"]\n",
    "    .shift(1).fillna(0).astype(int)\n",
    ")\n",
    "\n",
    "# A prior-year giving flag supports the eligibility definition used in the presentation narrative.\n",
    "account_year_full[\"gave_last_year\"] = (\n",
    "    account_year_full.groupby(\"account_id\")[\"gave_in_year\"]\n",
    "    .shift(1).fillna(0).astype(int)\n",
    ")\n",
    "\n",
    "# Lagged donation behavior is included as the compact, interpretable feature set.\n",
    "account_year_full[\"gift_count_last_year\"] = (\n",
    "    account_year_full.groupby(\"account_id\")[\"gift_count\"]\n",
    "    .shift(1).fillna(0).astype(int)\n",
    ")\n",
    "\n",
    "account_year_full[\"total_amount_last_year\"] = (\n",
    "    account_year_full.groupby(\"account_id\")[\"total_amount\"]\n",
    "    .shift(1).fillna(0.0)\n",
    ")\n",
    "\n",
    "# Eligibility enforces “at-risk donors” (gave last year + have at least 2 prior lifetime gifts).\n",
    "account_year_full[\"eligible_in_year\"] = (\n",
    "    (account_year_full[\"lifetime_gifts_through_last_year\"] >= 2) &\n",
    "    (account_year_full[\"gave_last_year\"] == 1)\n",
    ").astype(int)\n",
    "\n",
    "# The year-conditional lapse label is behavioral: eligible donors who do NOT give this year are labeled as lapsed.\n",
    "account_year_full[\"lapsed_in_year\"] = (\n",
    "    (account_year_full[\"eligible_in_year\"] == 1) &\n",
    "    (account_year_full[\"gave_in_year\"] == 0)\n",
    ").astype(int)\n",
    "\n",
    "print(\"Eligible rows:\", int(account_year_full[\"eligible_in_year\"].sum()))\n",
    "print(\"Lapsed rows:\", int(account_year_full[\"lapsed_in_year\"].sum()))"
   ]
  },
