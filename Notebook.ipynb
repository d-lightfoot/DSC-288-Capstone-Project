      "LogReg TEST metrics: {'precision': 0.6948751642575558, 'recall': 0.8507078507078507, 'f1': 0.7649356285259655, 'AUPRC': 0.7470302131552875}\n"
     ]
    },
    {
     "data": {
      "image/png": "",
