   "source": [
    "# Logistic Regression is used as a strong linear baseline with scaling and class balancing.\n",
    "best_lr = None\n",
    "\n",
    "for C in [0.01, 0.1, 1.0, 3.0, 10.0]:\n",
    "    lr = Pipeline([\n",
    "        (\"scaler\", StandardScaler()),\n",
    "        (\"clf\", LogisticRegression(max_iter=3000, class_weight=\"balanced\", C=C, random_state=RANDOM_SEED)),\n",
    "    ])\n",
    "    lr.fit(X_train, y_train)\n",
    "    val_prob = lr.predict_proba(X_val)[:, 1]\n",
    "    auprc = average_precision_score(y_val, val_prob)\n",
    "\n",
    "    if best_lr is None or auprc > best_lr[\"val_auprc\"]:\n",
    "        best_lr = {\"model\": lr, \"C\": C, \"val_auprc\": float(auprc)}\n",
    "\n",
    "print(\"Best LR C:\", best_lr[\"C\"], \"| VAL AUPRC:\", best_lr[\"val_auprc\"])\n",
    "\n",
    "X_trval = pd.concat([X_train, X_val])\n",
    "y_trval = pd.concat([y_train, y_val])\n",
    "\n",
    "best_lr[\"model\"].fit(X_trval, y_trval)\n",
    "lr_test_prob = best_lr[\"model\"].predict_proba(X_test)[:, 1]\n",
    "\n",
    "print(\"LogReg TEST metrics:\", eval_probs(y_test, lr_test_prob))\n",
    "plot_pr_curve(y_test, lr_test_prob, f\"Precision–Recall (LogReg) — Test {TEST_YEAR}\")"
   ]
  },
