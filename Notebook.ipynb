    "# A paste-ready report is generated to copy directly into slides, README, or the written narrative.\n",
    "def _df_to_markdown(df, floatfmt=3, max_rows=20):\n",
    "    df2 = df.copy()\n",
    "    if len(df2) > max_rows:\n",
    "        df2 = df2.head(max_rows)\n",
    "    for c in df2.columns:\n",
    "        if pd.api.types.is_float_dtype(df2[c]):\n",
    "            df2[c] = df2[c].map(lambda x: f\"{x:.{floatfmt}f}\")\n",
    "    return df2.to_markdown(index=False)\n",
    "\n",
    "def make_paste_report(summary_df, policy_df, title=\"Donor Lapse Model Results\"):\n",
    "    lines = []\n",
    "    lines.append(f\"# {title}\\n\")\n",
    "    lines.append(\"## Split\")\n",
    "    lines.append(f\"- Train years: {int(model_df.loc[train_mask,'donation_year'].min())}–{int(model_df.loc[train_mask,'donation_year'].max())}\")\n",
    "    lines.append(f\"- Validation year: {VAL_YEAR}\")\n",
    "    lines.append(f\"- Test year: {TEST_YEAR}\")\n",
    "    lines.append(f\"- Rows (train/val/test): {len(X_train):,} / {len(X_val):,} / {len(X_test):,}\")\n",
    "    lines.append(f\"- Positive rate (train/val/test): {float(y_train.mean()):.3f} / {float(y_val.mean()):.3f} / {float(y_test.mean()):.3f}\\n\")\n",
    "\n",
    "    lines.append(\"## Model results (Test)\")\n",
    "    lines.append(_df_to_markdown(summary_df))\n",
    "    lines.append(\"\")\n",
    "\n",
    "    lines.append(\"## Outreach policy (Top-K on Test)\")\n",
    "    lines.append(_df_to_markdown(policy_df))\n",
    "    lines.append(\"\")\n",
    "\n",
    "    lines.append(\"## Calibration\")\n",
    "    lines.append(f\"- Brier (uncalibrated): {base_brier:.4f}\")\n",
    "    lines.append(f\"- Brier (calibrated): {cal_brier:.4f}\")\n",
    "    lines.append(\"\")\n",
    "    return \"\\n\".join(lines)\n",
    "\n",
    "print(make_paste_report(summary, policy_df))"
   ]
