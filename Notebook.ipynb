   "source": [
    "# Donor-year aggregation is used to transform transaction logs into a predictive panel aligned with “next-year lapse”.\n",
    "account_year = (\n",
    "    df_clean.groupby([\"account_id\", \"donation_year\"], as_index=False)\n",
    "    .agg(\n",
    "        gift_count=(\"opportunity_id\", \"count\"),\n",
    "        total_amount=(\"amount\", \"sum\"),\n",
    "    )\n",
    ")\n",
    "\n",
    "# A binary “gave in year” indicator is defined explicitly for eligibility and label construction.\n",
    "account_year[\"gave_in_year\"] = (account_year[\"gift_count\"] > 0).astype(int)\n",
    "\n",
    "print(\"Account-year rows:\", account_year.shape[0])\n",
    "print(\"Year range:\", int(account_year[\"donation_year\"].min()), \"->\", int(account_year[\"donation_year\"].max()))\n",
    "display(account_year.head())"
   ]
