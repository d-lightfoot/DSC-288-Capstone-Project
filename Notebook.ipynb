    "# This notebook builds a leakage-safe donor-year panel from opportunity-level donations,\n",
    "# defines a year-conditional lapse label, and evaluates multiple binary classifiers.\n",
    "\n",
    "# A lightweight bootstrap is used so the live notebook runs cleanly even if the kernel starts bare.\n",
    "import sys\n",
    "import subprocess\n",
    "import importlib\n",
    "\n",
    "# A minimal dependency list is defined so later cells can import without interruption.\n",
    "REQUIRED = [\n",
    "    \"numpy\",\n",
    "    \"pandas\",\n",
    "    \"matplotlib\",\n",
    "    \"scikit-learn\",\n",
    "    \"xgboost\",\n",
    "    \"lightgbm\",\n",
    "    \"tabulate\",   # Added because pandas.to_markdown relies on it for report rendering\n",
    "]\n",
    "\n",
    "# A small helper is embedded here so missing packages can be installed without derailing the walkthrough.\n",
    "def _ensure(pkgs):\n",
    "    missing = []\n",
    "    for p in pkgs:\n",
    "        try:\n",
    "            importlib.import_module(p.replace(\"-\", \"_\"))\n",
    "        except Exception:\n",
    "            missing.append(p)\n",
    "\n",
    "    if missing:\n",
    "        print(\"Missing packages detected:\", missing)\n",
    "        cmd = [sys.executable, \"-m\", \"pip\", \"install\", \"--no-cache-dir\"] + missing\n",
    "        subprocess.check_call(cmd)\n",
    "        print(\"Installed:\", missing)\n",
    "    else:\n",
    "        print(\"All required packages already installed.\")\n",
    "\n",
    "_ensure(REQUIRED)"
   ]
