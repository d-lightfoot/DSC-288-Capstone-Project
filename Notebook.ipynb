   "source": [
    "# Top-K evaluation is included because outreach capacity is limited and ranking quality is what drives ROI.\n",
    "from sklearn.metrics import precision_recall_fscore_support\n",
    "\n",
    "def topk_policy_table(y_true, y_prob, Ks=(200, 500, 1000, 2000, 5000), label=\"Model\"):\n",
    "    y_true = np.asarray(y_true).astype(int)\n",
    "    y_prob = np.asarray(y_prob).astype(float)\n",
    "\n",
    "    base_rate = float(y_true.mean())\n",
    "    order = np.argsort(-y_prob)\n",
    "\n",
    "    rows = []\n",
    "    for K in Ks:\n",
    "        K = int(min(K, len(y_true)))\n",
    "        topk = order[:K]\n",
    "\n",
    "        y_pred = np.zeros_like(y_true)\n",
    "        y_pred[topk] = 1\n",
    "\n",
    "        p, r, f1, _ = precision_recall_fscore_support(y_true, y_pred, average=\"binary\", zero_division=0)\n",
    "\n",
    "        captured = int(y_true[topk].sum())\n",
    "        lift = float(p / base_rate) if base_rate > 0 else np.nan\n",
    "\n",
    "        rows.append({\n",
    "            \"model\": label,\n",
    "            \"K\": K,\n",
    "            \"base_rate\": base_rate,\n",
    "            \"captured_positives@K\": captured,\n",
    "            \"precision@K\": float(p),\n",
    "            \"recall@K\": float(r),\n",
    "            \"f1@K\": float(f1),\n",
    "            \"lift@K\": float(lift),\n",
    "        })\n",
    "\n",
    "    return pd.DataFrame(rows).sort_values(\"K\")\n",
    "\n",
    "def plot_topk_curves(y_true, y_prob, K_max=5000, step=100, label=\"Model\"):\n",
    "    y_true = np.asarray(y_true).astype(int)\n",
    "    y_prob = np.asarray(y_prob).astype(float)\n",
    "\n",
    "    n = len(y_true)\n",
    "    K_max = int(min(K_max, n))\n",
    "    Ks = list(range(step, K_max + 1, step))\n",
    "\n",
    "    order = np.argsort(-y_prob)\n",
    "    base_rate = float(y_true.mean())\n",
    "\n",
    "    precisions, recalls, lifts = [], [], []\n",
    "    for K in Ks:\n",
    "        topk = order[:K]\n",
    "        captured = float(y_true[topk].sum())\n",
    "        p = captured / K\n",
    "        r = captured / float(y_true.sum()) if float(y_true.sum()) > 0 else 0.0\n",
    "        lift = p / base_rate if base_rate > 0 else np.nan\n",
    "\n",
    "        precisions.append(p)\n",
    "        recalls.append(r)\n",
    "        lifts.append(lift)\n",
    "\n",
    "    plt.figure()\n",
    "    plt.plot(Ks, precisions)\n",
    "    plt.xlabel(\"K (donors contacted)\")\n",
    "    plt.ylabel(\"Precision@K\")\n",
    "    plt.title(f\"Precision@K vs K — {label}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    plt.figure()\n",
    "    plt.plot(Ks, recalls)\n",
    "    plt.xlabel(\"K (donors contacted)\")\n",
    "    plt.ylabel(\"Recall@K\")\n",
    "    plt.title(f\"Recall@K vs K — {label}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "    plt.figure()\n",
    "    plt.plot(Ks, lifts)\n",
    "    plt.xlabel(\"K (donors contacted)\")\n",
    "    plt.ylabel(\"Lift@K (Precision@K / Base rate)\")\n",
    "    plt.title(f\"Lift@K vs K — {label}\")\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "policy_df = topk_policy_table(\n",
    "    y_true=y_test.values,\n",
    "    y_prob=cal_prob,\n",
    "    Ks=(200, 500, 1000, 2000, 5000),\n",
    "    label=\"XGBoost_Calibrated\",\n",
    ")\n",
    "display(policy_df)\n",
    "\n",
    "plot_topk_curves(\n",
    "    y_true=y_test.values,\n",
    "    y_prob=cal_prob,\n",
    "    K_max=5000,\n",
    "    step=100,\n",
    "    label=\"XGBoost_Calibrated\",\n",
    ")"
   ]
  },
